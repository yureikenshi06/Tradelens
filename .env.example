# ── Copy this to .env and fill in your values ─────────────────────────────────
# NEVER commit .env to git (.gitignore already excludes it)

# Supabase — get from supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Binance Futures API — get from Binance → API Management
# These are server-side only (NOT prefixed with VITE_)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Groq AI — FREE — get from console.groq.com → API Keys (30 seconds)
# This is server-side only (NOT prefixed with VITE_)
GROQ_API_KEY=your_groq_api_key_here
