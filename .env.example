# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Supabase (required for auth + notes persistence) ──────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Binance (for the serverless API route — set in Vercel dashboard, NOT here) ─
# BINANCE_SECRET=your_binance_api_secret_key

# ── CORS (set to your Vercel deployment URL) ──────────────────────────────────
# ALLOWED_ORIGIN=https://yourapp.vercel.app
